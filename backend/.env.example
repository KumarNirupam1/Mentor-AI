PORT=
CORS_ORIGIN=
FRONTEND_URL=

MONGODB_URI=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URI=

ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=
REFRESH_TOKEN_EXPIRY=

# No shared OpenAI key — users add their own via the app UI

# Required: encrypts user OpenAI keys at rest in MongoDB (min 32 chars)
ENCRYPTION_SECRET=your_long_random_encryption_secret_at_least_32_chars

# Optional: per-mentor message limits (defaults: 10 messages, 10 min cooldown)
PERSONA_MESSAGE_LIMIT=10
PERSONA_COOLDOWN_MINUTES=10
